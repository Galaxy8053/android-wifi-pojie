    <string name="app_name">WiFi Toolbox</string>
    <string name="failure_flag_help_text">Used to determine a single attempt failure:\n• Password Incorrect: Standard connection failure, most stable but slowest.\n• Handshake Timeout: Fails by monitoring the start time of handshake events, faster.\n• Handshake Over-limit (Recommended): Captures detailed system logs via logcat; fails after specified handshake counts. Fastest and more stable than timeout.</string>
    <string name="error_algin_help_text">Retry when a single attempt exceeds the maximum time.\nThis usually happens due to failed requests or poor signal.\n• Retry Count: Max retries for a single password.\n• Backoff Base: Delay before retrying to avoid being ignored by the router; this base doubles with each consecutive failure.</string>
    <string name="default_script_content">// ==ToolboxScript==\n// @id {ID}\n// @name Script Name\n// @description Script Description\n// @author Author\n// @version 1.0.0\n// ==/ToolboxScript==\n\nconsole.log(\"Adding a password…\")\ntask.addItem(\"12345678\")\nconsole.log(\"Waiting for 1s…\")\nawait wait(1000);\nconsole.log(\"Adding another one!\");\ntask.addItem(\"88888888\")\n\ntry {\n\tconsole.log(\"Testing network request…\");\n\tconst response = await fetch(\'https://uapis.cn/api/v1/network/myip\');\n\tconst data = await response.json();\n\tconsole.log(\"Local IP: \" + data.ip);\n\tconsole.log(\"Region: \" + data.region);\n} catch (err) {\n\tconsole.log(\"Request failed: \" + err.message);\n}\nconsole.log(\"Done\");</string>
